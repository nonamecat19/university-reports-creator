# =============================================================================
# Service Discovery (local mode - no Consul needed)
# =============================================================================
# Set these so gateway knows where other services are
SERVICE_AUTH=:50051
SERVICE_DOCUMENT=:50052
SERVICE_FILES=:50053

# =============================================================================
# Service Auth
# =============================================================================
GRPC_PORT=:50051
JWT_SECRET=change-me-to-a-strong-secret
ACCESS_TOKEN_DURATION=15m
REFRESH_TOKEN_DURATION=168h
DATABASE_URL=postgres://postgres:postgres@localhost:5432/auth?sslmode=disable

# =============================================================================
# Service Document
# =============================================================================
GRPC_PORT=:50052
SURREALDB_URL=ws://localhost:8000
SURREALDB_USERNAME=root
SURREALDB_PASSWORD=root
SURREALDB_NAMESPACE=diploma
SURREALDB_DATABASE=main

# =============================================================================
# Service Files
# =============================================================================
GRPC_PORT=:50053
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=files
MINIO_USE_SSL=false

# =============================================================================
# Service Gateway
# =============================================================================
HTTP_PORT=:8080

# =============================================================================
# Infrastructure
# =============================================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=auth
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin